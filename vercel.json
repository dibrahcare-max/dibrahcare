{
  "crons": [
    {
      "path": "/api/cron/remind",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/whatsapp-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/admin",
      "destination": "/404",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*).ttf",
      "headers": [
        { "key": "Content-Type", "value": "font/ttf" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
